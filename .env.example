# --- Lead pipeline (brief §13) ----------------------------------------------
# Copy this file to ".env" and fill in the real values, then restart the dev
# server / rebuild. Until VITE_CRM_ENDPOINT is set, the quote form runs in a
# safe "simulated submit" mode (logs the payload to the console — never lost).

# CONFIRM with MR Print World: exact endpoint URL, HTTP method, payload shape
# and auth. submitLead() in src/lib/crm.js POSTs JSON to this URL.
VITE_CRM_ENDPOINT=https://crm.mrprintworld.com/api/leads

# Optional — if the CRM needs a key, it is sent as "Authorization: Bearer <key>"
VITE_CRM_API_KEY=
